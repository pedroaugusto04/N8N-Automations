NODE_ENV=production
N8N_IMAGE=n8nio/n8n:latest
N8N_RESTART_POLICY=always
N8N_BIND_PORT=5678
HOST_DOCKER_INTERNAL_IP=127.0.0.1
N8N_HOST=example.com
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_PATH=/n8n/
N8N_EDITOR_BASE_URL=https://example.com/n8n/
WEBHOOK_URL=https://example.com/n8n/
N8N_PROXY_HOPS=1
GENERIC_TIMEZONE=America/Sao_Paulo
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=change-me
N8N_BASIC_AUTH_PASSWORD=change-me
NODES_EXCLUDE=[]
N8N_DATA_DIR=/home/ubuntu/n8n-private/data
TELEGRAM_CHAT_ID=change-me
VPS_TELEGRAM_CHAT_ID=change-me
FECONECT_TELEGRAM_CHAT_ID=change-me
DEV_NEWS_TELEGRAM_CHAT_ID=change-me
GOOGLE_API_KEY=change-me
FECONECT_APP_PING_URL=https://example.com/feconnect/api/ping
KB_WEBHOOK_SECRET=change-me
KB_GITHUB_APP_WEBHOOK_SECRET=change-me
KB_OPENAI_API_KEY=
KB_OPENAI_MODEL=gpt-4.1-mini
KB_ENABLE_GIT_PUSH=false
KB_VAULT_REMOTE_URL=
KB_VAULT_GIT_USER_NAME=knowledge-bot
KB_VAULT_GIT_USER_EMAIL=knowledge-bot@example.local
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
CONTAINER_ALERT_COOLDOWN_HOURS=5
CONTAINER_PING_TIMEOUT_MS=10000
CONTAINER_PING_TARGETS={"service-name":"https://example.com/health"}
DB_BACKUP_CRON=0 3 * * *
DB_BACKUP_TIMEZONE=America/Sao_Paulo
DB_BACKUP_LOCAL_DIR=/home/ubuntu/n8n-private/backups/databases
DB_BACKUP_DRIVE_REMOTE=gdrive
DB_BACKUP_DRIVE_FOLDER=db_backups
DB_BACKUP_LOCAL_RETENTION_DAYS=7
DB_BACKUP_DRIVE_RETENTION_DAYS=30
DB_BACKUP_TARGETS_JSON=[{"name":"feconect-postgres","type":"postgres","host":"127.0.0.1","port":5432,"database":"fe_conect_db","username":"postgres","password":"change-me","extra_args":"--clean --if-exists"}]
