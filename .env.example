NODE_ENV=production
N8N_IMAGE=n8nio/n8n:latest
N8N_RESTART_POLICY=always
N8N_BIND_PORT=5678
HOST_DOCKER_INTERNAL_IP=127.0.0.1
N8N_HOST=example.com
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_PATH=/n8n/
N8N_EDITOR_BASE_URL=https://example.com/n8n/
WEBHOOK_URL=https://example.com/n8n/
GENERIC_TIMEZONE=America/Sao_Paulo
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=change-me
N8N_BASIC_AUTH_PASSWORD=change-me
TELEGRAM_CHAT_ID=change-me
VPS_TELEGRAM_CHAT_ID=change-me
FECONECT_TELEGRAM_CHAT_ID=change-me
DEV_NEWS_TELEGRAM_CHAT_ID=change-me
GOOGLE_API_KEY=change-me
FECONECT_APP_PING_URL=https://example.com/feconnect/api/ping
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
CONTAINER_ALERT_COOLDOWN_HOURS=5
CONTAINER_PING_TIMEOUT_MS=10000
CONTAINER_PING_TARGETS={"service-name":"https://example.com/health"}
