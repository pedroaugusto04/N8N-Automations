NODE_ENV=production
N8N_IMAGE=n8nio/n8n:latest
N8N_RESTART_POLICY=always
HOST_DOCKER_INTERNAL_IP=127.0.0.1
N8N_HOST=example.com
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_PATH=/n8n/
N8N_EDITOR_BASE_URL=https://example.com/n8n/
WEBHOOK_URL=https://example.com/n8n/
N8N_PROXY_HOPS=1
GENERIC_TIMEZONE=America/Sao_Paulo
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=change-me
N8N_BASIC_AUTH_PASSWORD=change-me
NODES_EXCLUDE=[]
N8N_DATA_DIR=/home/ubuntu/n8n-private/data
TELEGRAM_CHAT_ID=change-me
VPS_TELEGRAM_CHAT_ID=change-me
FECONECT_TELEGRAM_CHAT_ID=change-me
DEV_NEWS_TELEGRAM_CHAT_ID=change-me
GOOGLE_API_KEY=change-me
FECONECT_APP_PING_URL=https://example.com/feconnect/api/ping
KB_WEBHOOK_SECRET=change-me
KB_GITHUB_APP_WEBHOOK_SECRET=change-me
KB_GITHUB_API_TOKEN=change-me
KB_REVIEW_AI_PROVIDER=openrouter
KB_REVIEW_AI_BASE_URL=https://openrouter.ai/api/v1
KB_REVIEW_AI_MODEL=openrouter/auto
KB_REVIEW_AI_API_KEY=change-me
KB_CONVERSATION_AI_PROVIDER=openrouter
KB_CONVERSATION_AI_BASE_URL=https://openrouter.ai/api/v1
KB_CONVERSATION_AI_MODEL=openrouter/auto
KB_CONVERSATION_AI_API_KEY=change-me
KB_TELEGRAM_BOT_TOKEN=change-me
KB_TELEGRAM_CHAT_ID=change-me
KB_ENABLE_GIT_PUSH=false
KB_GIT_BATCH_MODE=true
KB_GITHUB_WEBHOOK_PATH=/n8n/webhook/kb-github-push
KB_INGEST_WEBHOOK_PATH=/n8n/webhook/kb-event
KB_WPP_WEBHOOK_PATH=/n8n/webhook/whatsapp-kb-event
KB_ONBOARDING_WEBHOOK_PATH=/n8n/webhook/kb-onboarding
KB_QUERY_WEBHOOK_PATH=/n8n/webhook/kb-query
KB_PUBLIC_BASE_URL=https://example.com
KB_GITHUB_APP_INSTALL_URL=https://github.com/apps/your-app/installations/new
KB_WPP_PAIRING_URL=https://example.com/connect-whatsapp
KB_MAX_DIFF_CHARS=60000
KB_VAULT_PATH=/home/node/knowledge-vault
KB_ARCHIVE_PATH=/home/node/knowledge-vault-archive
KB_PROJECTS_MANIFEST=/home/node/knowledge-base/projects.json
KB_WORKSPACES_MANIFEST=/home/node/knowledge-base/workspaces.json
KB_VAULT_REMOTE_URL=
KB_VAULT_GIT_USER_NAME=knowledge-bot
KB_VAULT_GIT_USER_EMAIL=knowledge-bot@example.local
KB_VAULT_GIT_PUSH_USERNAME=
KB_VAULT_GIT_PUSH_TOKEN=
KB_ATTACHMENT_MAX_VAULT_BYTES=10485760
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
CONTAINER_ALERT_COOLDOWN_HOURS=5
CONTAINER_PING_TIMEOUT_MS=10000
CONTAINER_PING_TARGETS={"service-name":"https://example.com/health"}
DB_BACKUP_CRON=0 3 * * *
DB_BACKUP_TIMEZONE=America/Sao_Paulo
DB_BACKUP_LOCAL_DIR=/home/ubuntu/n8n-private/backups/databases
DB_BACKUP_DRIVE_REMOTE=gdrive
DB_BACKUP_DRIVE_FOLDER=db_backups
DB_BACKUP_LOCAL_RETENTION_DAYS=7
DB_BACKUP_DRIVE_RETENTION_DAYS=30
DB_BACKUP_TARGETS_JSON=[{"name":"feconect-postgres","type":"postgres","host":"127.0.0.1","port":5432,"database":"fe_conect_db","username":"postgres","password":"change-me","extra_args":"--clean --if-exists"}]
EVOLUTION_API_KEY=change-me
EVOLUTION_API_PORT=8081
EVOLUTION_API_URL=http://127.0.0.1:8081
EVOLUTION_API_PUBLIC_URL=https://example.com:8081
EVOLUTION_INSTANCE_NAME=kb-bot
WPP_KB_GROUP_JID=120363XXXXXXXXX@g.us
WPP_CONVERSATION_TIMEOUT_MS=600000
