# Copy to: ~/.config/kb-note/config.env

# Remote-first kb CLI endpoint (required unless WEBHOOK_URL is set)
KB_WEBHOOK_URL=https://example.com/n8n/webhook/gH8xKbIngest0001/webhook/kb-event

# Shared secret required by the ingestion webhook
KB_WEBHOOK_SECRET=change-me

# Optional fallback base URL used to derive KB_WEBHOOK_URL automatically
# WEBHOOK_URL=https://example.com/n8n/

# Optional fallback project when auto detection fails
# KB_NOTE_DEFAULT_PROJECT=inbox
