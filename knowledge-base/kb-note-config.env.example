# Copy to: ~/.config/kb-note/config.env

# Vault root used by kb-note/kb-bug/kb-resume/kb-article
KB_VAULT_DIR=/home/ubuntu/knowledge-vault

# Optional: override projects manifest used for auto project detection.
# KB_PROJECTS_MANIFEST=/home/ubuntu/n8n/knowledge-base/projects.json

# Optional: fallback project when auto detection fails (default: inbox)
# KB_NOTE_DEFAULT_PROJECT=inbox
