#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${KB_NOTE_CONFIG_FILE:-$HOME/.config/kb-note/config.env}"
MANIFEST_PATH="${KB_PROJECTS_MANIFEST:-/home/ubuntu/n8n/knowledge-base/projects.json}"

if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

WEBHOOK_URL="${KB_WEBHOOK_URL:-${KB_NOTE_WEBHOOK_URL:-}}"
WEBHOOK_SECRET="${KB_WEBHOOK_SECRET:-${KB_NOTE_WEBHOOK_SECRET:-}}"

usage() {
  cat <<'EOF'
Usage:
  kb-note [--project <slug>] [--title <text>] [--file <path>] [text]

Examples:
  kb-note "ajuste temporario no fluxo do billing"
  kb-note --project wander-rag --title "ideia" "avaliar chunking melhor"
  kb-note --file /tmp/note.txt
EOF
}

PROJECT_SLUG=""
TITLE=""
FILE_PATH=""
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)
      PROJECT_SLUG="${2:-}"
      shift 2
      ;;
    --title)
      TITLE="${2:-}"
      shift 2
      ;;
    --file)
      FILE_PATH="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      ;;
  esac
done

TEXT_INPUT="${POSITIONAL[*]:-}"
if [[ -n "$FILE_PATH" ]]; then
  TEXT_INPUT="$(cat "$FILE_PATH")"
fi

if [[ -z "$TEXT_INPUT" ]]; then
  TMP_FILE="$(mktemp)"
  trap 'rm -f "$TMP_FILE"' EXIT
  "${EDITOR:-nano}" "$TMP_FILE"
  TEXT_INPUT="$(cat "$TMP_FILE")"
fi

if [[ -z "${TEXT_INPUT// }" ]]; then
  echo "kb-note: empty note" >&2
  exit 1
fi

if [[ -z "$WEBHOOK_SECRET" ]]; then
  echo "kb-note: KB_WEBHOOK_SECRET is not configured" >&2
  exit 1
fi

if [[ -z "$WEBHOOK_URL" ]]; then
  echo "kb-note: KB_WEBHOOK_URL is not configured" >&2
  exit 1
fi

REPO_ROOT=""
REPO_FULL_NAME=""
BRANCH=""
HEAD_SHA=""

if git rev-parse --show-toplevel >/dev/null 2>&1; then
  REPO_ROOT="$(git rev-parse --show-toplevel)"
  REMOTE_URL="$(git -C "$REPO_ROOT" remote get-url origin 2>/dev/null || true)"
  BRANCH="$(git -C "$REPO_ROOT" branch --show-current 2>/dev/null || true)"
  HEAD_SHA="$(git -C "$REPO_ROOT" rev-parse HEAD 2>/dev/null || true)"
  if [[ -n "$REMOTE_URL" ]]; then
    REPO_FULL_NAME="$(python3 - "$REMOTE_URL" <<'PY'
import re, sys
remote = sys.argv[1].strip()
patterns = [
    r'github\.com[:/](?P<name>[^/]+/[^/.]+)(?:\.git)?$',
]
for pattern in patterns:
    match = re.search(pattern, remote)
    if match:
        print(match.group('name'))
        raise SystemExit(0)
print('')
PY
)"
  fi
fi

if [[ -z "$PROJECT_SLUG" && -n "$REPO_FULL_NAME" && -f "$MANIFEST_PATH" ]]; then
  PROJECT_SLUG="$(python3 - "$MANIFEST_PATH" "$REPO_FULL_NAME" <<'PY'
import json, sys
manifest_path, repo = sys.argv[1], sys.argv[2]
with open(manifest_path, 'r', encoding='utf-8') as handle:
    manifest = json.load(handle)
for item in manifest.get('projects', []):
    if item.get('repo_full_name') == repo:
        print(item.get('project_slug', ''))
        raise SystemExit(0)
print('')
PY
)"
fi

if [[ -z "$PROJECT_SLUG" ]]; then
  echo "kb-note: could not infer project slug, use --project" >&2
  exit 1
fi

MANUAL_NOTE_ID="$(python3 - <<'PY'
import secrets
print(secrets.token_hex(8))
PY
)"

PAYLOAD="$(python3 - "$PROJECT_SLUG" "$TITLE" "$TEXT_INPUT" "$REPO_FULL_NAME" "$BRANCH" "$HEAD_SHA" "$MANUAL_NOTE_ID" <<'PY'
import json, os, socket, sys
from datetime import datetime, timezone
project_slug, title, text_input, repo_full_name, branch, head_sha, manual_note_id = sys.argv[1:8]
payload = {
    "event_id": f"manual_note:{project_slug}:{manual_note_id}",
    "event_type": "manual_note",
    "project_slug": project_slug,
    "repo": repo_full_name,
    "branch": branch,
    "triggered_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "source_actor": os.environ.get("USER", "unknown"),
    "source": "kb-note",
    "manual_note_id": manual_note_id,
    "raw_text": text_input,
    "title": title,
    "head_sha": head_sha,
    "delivery_ref": f"{socket.gethostname()}:{manual_note_id}",
    "tags": ["manual-note", "cli"],
}
print(json.dumps(payload, ensure_ascii=True))
PY
)"

curl --silent --show-error --fail \
  -X POST "$WEBHOOK_URL" \
  -H 'content-type: application/json' \
  -H "x-kb-secret: $WEBHOOK_SECRET" \
  --data "$PAYLOAD"
