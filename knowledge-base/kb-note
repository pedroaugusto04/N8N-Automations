#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${KB_NOTE_CONFIG_FILE:-$HOME/.config/kb-note/config.env}"

if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

KB_NOTE_URL="${KB_NOTE_URL:-${KB_AGENT_URL:-}}"
KB_NOTE_SECRET="${KB_NOTE_SECRET:-${KB_AGENT_SECRET:-}}"
usage() {
  cat <<'EOF'
Usage:
  kb-note [--file <path>] [text]

Examples:
  kb-note "salve um resumo do erro do webhook na pasta bugs"
  kb-note --file /tmp/note.txt
EOF
}

FILE_PATH=""
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --file)
      FILE_PATH="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      ;;
  esac
done

TEXT_INPUT="${POSITIONAL[*]:-}"
if [[ -n "$FILE_PATH" ]]; then
  TEXT_INPUT="$(cat "$FILE_PATH")"
fi

if [[ -z "$TEXT_INPUT" ]]; then
  TMP_FILE="$(mktemp)"
  trap 'rm -f "$TMP_FILE"' EXIT
  "${EDITOR:-nano}" "$TMP_FILE"
  TEXT_INPUT="$(cat "$TMP_FILE")"
fi

if [[ -z "${TEXT_INPUT// }" ]]; then
  echo "kb-note: empty note" >&2
  exit 1
fi

if [[ -z "$KB_NOTE_SECRET" ]]; then
  echo "kb-note: KB_NOTE_SECRET is not configured" >&2
  exit 1
fi

if [[ -z "$KB_NOTE_URL" ]]; then
  echo "kb-note: KB_NOTE_URL is not configured" >&2
  exit 1
fi

PAYLOAD="$(python3 - "$TEXT_INPUT" <<'PY'
import json, sys
prompt = sys.argv[1]
payload = {"prompt": prompt}
print(json.dumps(payload, ensure_ascii=True))
PY
)"

curl --silent --show-error --fail \
  -X POST "$KB_NOTE_URL" \
  -H 'content-type: application/json' \
  -H "x-kb-secret: $KB_NOTE_SECRET" \
  --data "$PAYLOAD"
