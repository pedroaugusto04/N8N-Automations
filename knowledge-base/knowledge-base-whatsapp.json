        "parameters": {
          "jsCode": "const input = {\n  message_text: $json.message_text || '',\n  sender_jid: $json.sender_jid || '',\n  group_jid: $json.group_jid || '',\n  message_id: $json.message_id || '',\n  has_media: $json.has_media || false,\n  media_type: $json.media_type || '',\n  media_file_name: $json.media_file_name || '',\n  media_mime_type: $json.media_mime_type || '',\n  media_file_size: $json.media_file_size || 0,\n  media_data_b64: $json.media_data_b64 || '',\n};\nconst inputB64 = Buffer.from(JSON.stringify(input), 'utf8').toString('base64');\nconst tmpPath = `/tmp/kb-wpp-input-${Date.now()}-${Math.random().toString(16).slice(2)}.b64`;\nreturn [{ json: { input_b64: inputB64, input_file_path: tmpPath } }];"
        },
