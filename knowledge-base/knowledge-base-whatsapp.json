        "id": "wa-run-processor-001",
        "name": "Run Processor",
        "type": "n8n-nodes-base.executeCommand",
        "typeVersion": 1,
        "position": [
          3120,
          300
        ]
      },
      {
        "parameters": {
          "jsCode": "const stdout = String($json.stdout || '').trim();\nlet parsed;\ntry {\n  parsed = JSON.parse(stdout || '{}');\n} catch {\n  parsed = { ok: false, message: stdout || 'processor returned no json' };\n}\n\nlet confirmText = '';\nif (parsed.ok) {\n  const parts = ['✅ *Nota salva no vault!*'];\n  if (parsed.project) parts.push(`Projeto: ${parsed.project}`);\n  if (parsed.kind) parts.push(`Tipo: ${parsed.kind}`);\n  if (parsed.notePath) parts.push(`Nota: ${parsed.notePath}`);\n  if (parsed.reminderPath) parts.push(`Lembrete: ${parsed.reminderPath}`);\n  if (parsed.attachmentPath) parts.push(`Anexo: ${parsed.attachmentPath}`);\n  confirmText = parts.join('\\n');\n} else {\n  confirmText = `⚠️ Erro ao salvar nota: ${parsed.message || 'erro desconhecido'}`;\n}\n\nreturn [{ json: { ...parsed, confirm_text: confirmText } }];"
        },
