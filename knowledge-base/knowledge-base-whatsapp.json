      {
        "parameters": {
          "jsCode": "const payload = $node['Parse Conversation Result'].json.payload;\nif (!payload || typeof payload !== 'object') {\n  return [{ json: { ok: false, message: 'no_payload_to_submit' } }];\n}\n\nconst wrapped = {\n  headers: { 'x-kb-secret': $env.KB_WEBHOOK_SECRET || '' },\n  body: payload,\n  binaries: {},\n  raw_body_b64: '',\n};\nconst b64 = Buffer.from(JSON.stringify(wrapped), 'utf8').toString('base64');\nconst filePath = `/tmp/kb-wpp-payload-${Date.now()}.b64`;\nreturn [{ json: { payload_b64: b64, payload_file_path: filePath } }];"
        },
