#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${KB_NOTE_CONFIG_FILE:-$HOME/.config/kb-note/config.env}"

if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

MAX_INLINE_ATTACHMENT_BYTES=$((10 * 1024 * 1024))

usage() {
  cat <<'USAGE'
Usage:
  kb "<texto livre>" [--path /arquivo] [--project slug] [--kind manual_note|bug|resume|article|daily] [--note-type event|knowledge|decision|incident] [--importance low|medium|high] [--status open|active|resolved|archived] [--follow-up-by 2026-04-30] [--reminder-date DD/MM/AAAA] [--reminder-time HH:mm] [--decision] [--related-projects a,b] [--tags a,b] [--default]

Examples:
  kb "corrigi timeout no webhook"
  kb "erro 401 no webhook de ingestao" --kind bug --project n8n-automations
  kb "padronizar deploy do backend" --note-type knowledge --importance high --related-projects fe-connect,wander-rag
  kb "referencia do parser para revisao" --path ./knowledge-base/process-event-v2.mjs --tags parser,ingestion
USAGE
}

join_url() {
  local base="${1%/}"
  local suffix="${2#/}"
  printf '%s/%s' "$base" "$suffix"
}

slugify() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9-]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'
}

trim_spaces() {
  printf '%s' "$1" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//'
}

add_unique_choice() {
  local value="$1"
  local label="$2"
  local -n values_ref="$3"
  local -n labels_ref="$4"
  local existing

  [[ -n "$value" ]] || return 0
  for existing in "${values_ref[@]:-}"; do
    [[ "$existing" == "$value" ]] && return 0
  done

  values_ref+=("$value")
  labels_ref+=("$label")
}

prompt_numbered_choice() {
  local prompt="$1"
  local default_index="$2"
  local values_name="$3"
  local labels_name="$4"
  local -n values_ref="$values_name"
  local -n labels_ref="$labels_name"
  local answer=""
  local display_index=0
  local selected_index=0

  while true; do
    printf '%s\n' "$prompt" >&2
    for selected_index in "${!values_ref[@]}"; do
      display_index=$((selected_index + 1))
      if (( selected_index == default_index )); then
        printf '  %d) %s [padrao]\n' "$display_index" "${labels_ref[$selected_index]}" >&2
      else
        printf '  %d) %s\n' "$display_index" "${labels_ref[$selected_index]}" >&2
      fi
    done

    if (( default_index >= 0 )); then
      printf 'Escolha um numero [%d]: ' $((default_index + 1)) >&2
    else
      printf 'Escolha um numero: ' >&2
    fi

    answer=""
    if ! read -r answer; then
      echo "kb: entrada encerrada ao solicitar uma escolha interativa." >&2
      exit 1
    fi

    answer="$(trim_spaces "$answer")"
    if [[ -z "$answer" ]] && (( default_index >= 0 )); then
      printf '%s' "${values_ref[$default_index]}"
      return 0
    fi

    if [[ "$answer" =~ ^[0-9]+$ ]]; then
      selected_index=$((answer - 1))
      if (( selected_index >= 0 && selected_index < ${#values_ref[@]} )); then
        printf '%s' "${values_ref[$selected_index]}"
        return 0
      fi
    fi

    echo "kb: escolha invalida. Digite um numero entre 1 e ${#values_ref[@]}." >&2
  done
}

kind_description() {
  case "$1" in
    manual_note) printf 'manual_note - anotacao manual geral' ;;
    bug) printf 'bug - erro, falha ou incidente' ;;
    resume) printf 'resume - resumo, sintese ou recap' ;;
    article) printf 'article - artigo, tutorial ou documentacao' ;;
    daily) printf 'daily - diario, standup ou registro do dia' ;;
    *) printf '%s' "$1" ;;
  esac
}

validate_reminder_date_br() {
  local value="$1"
  local day=""
  local month=""
  local year=""
  local normalized=""
  local formatted=""

  [[ "$value" =~ ^([0-9]{2})/([0-9]{2})/([0-9]{4})$ ]] || return 1
  day="${BASH_REMATCH[1]}"
  month="${BASH_REMATCH[2]}"
  year="${BASH_REMATCH[3]}"
  normalized="${year}-${month}-${day}"
  formatted="$(date -d "$normalized" +%d/%m/%Y 2>/dev/null || true)"
  [[ "$formatted" == "$value" ]]
}

normalize_reminder_date_br() {
  local value="$1"
  [[ "$value" =~ ^([0-9]{2})/([0-9]{2})/([0-9]{4})$ ]] || return 1
  printf '%s-%s-%s' "${BASH_REMATCH[3]}" "${BASH_REMATCH[2]}" "${BASH_REMATCH[1]}"
}

validate_reminder_time() {
  local value="$1"
  [[ "$value" =~ ^([01][0-9]|2[0-3]):([0-5][0-9])$ ]]
}

prompt_optional_input() {
  local prompt="$1"
  local answer=""

  printf '%s' "$prompt" >&2
  if ! read -r answer; then
    echo "kb: entrada encerrada durante o preenchimento interativo." >&2
    exit 1
  fi
  trim_spaces "$answer"
}

collect_reminder_schedule() {
  local reminder_date_input=""
  local reminder_time_input=""

  while true; do
    reminder_date_input="$(
      prompt_optional_input \
        "kb: data do lembrete (DD/MM/AAAA, enter para ignorar): "
    )"
    if [[ -z "$reminder_date_input" ]]; then
      REMINDER_DATE=""
      REMINDER_TIME=""
      REMINDER_AT=""
      return 0
    fi
    if validate_reminder_date_br "$reminder_date_input"; then
      REMINDER_DATE="$(normalize_reminder_date_br "$reminder_date_input")"
      break
    fi
    echo "kb: data invalida. Use o formato DD/MM/AAAA." >&2
  done

  while true; do
    reminder_time_input="$(
      prompt_optional_input \
        "kb: horario do lembrete (HH:mm, enter para deixar sem horario exato): "
    )"
    if [[ -z "$reminder_time_input" ]]; then
      REMINDER_TIME=""
      REMINDER_AT=""
      return 0
    fi
    if validate_reminder_time "$reminder_time_input"; then
      REMINDER_TIME="$reminder_time_input"
      REMINDER_AT="${REMINDER_DATE}T${REMINDER_TIME}:00-03:00"
      return 0
    fi
    echo "kb: horario invalido. Use o formato HH:mm." >&2
  done
}

build_kind_choices() {
  local recommended_kind="$1"
  KIND_OPTION_VALUES=()
  KIND_OPTION_LABELS=()

  add_unique_choice "$recommended_kind" "$(kind_description "$recommended_kind")" KIND_OPTION_VALUES KIND_OPTION_LABELS
  add_unique_choice "manual_note" "$(kind_description "manual_note")" KIND_OPTION_VALUES KIND_OPTION_LABELS
  add_unique_choice "bug" "$(kind_description "bug")" KIND_OPTION_VALUES KIND_OPTION_LABELS
  add_unique_choice "resume" "$(kind_description "resume")" KIND_OPTION_VALUES KIND_OPTION_LABELS
  add_unique_choice "article" "$(kind_description "article")" KIND_OPTION_VALUES KIND_OPTION_LABELS
  add_unique_choice "daily" "$(kind_description "daily")" KIND_OPTION_VALUES KIND_OPTION_LABELS
}

load_manifest_projects() {
  local manifest="$1"

  [[ -f "$manifest" ]] || return 0

  node -e '
const fs = require("fs");
const manifest = process.argv[1];
try {
  const data = JSON.parse(fs.readFileSync(manifest, "utf8"));
  const projects = Array.isArray(data?.projects) ? data.projects : [];
  for (const project of projects) {
    if (project?.enabled === false) continue;
    const slug = String(project?.project_slug || "").trim();
    if (!slug) continue;
    const display = String(project?.display_name || slug).trim();
    process.stdout.write(`${slug}\t${display}\n`);
  }
} catch {}
' "$manifest"
}

build_project_choices() {
  local manifest="$1"
  local detected_project="$2"
  local default_project="$3"
  local slug=""
  local display_name=""
  PROJECT_OPTION_VALUES=()
  PROJECT_OPTION_LABELS=()

  if [[ -n "$detected_project" ]]; then
    add_unique_choice \
      "$detected_project" \
      "$detected_project - projeto detectado pelo repositorio atual" \
      PROJECT_OPTION_VALUES \
      PROJECT_OPTION_LABELS
  fi

  if [[ -n "$default_project" ]]; then
    add_unique_choice \
      "$default_project" \
      "$default_project - projeto padrao configurado" \
      PROJECT_OPTION_VALUES \
      PROJECT_OPTION_LABELS
  fi

  add_unique_choice \
    "inbox" \
    "inbox - caixa de entrada geral" \
    PROJECT_OPTION_VALUES \
    PROJECT_OPTION_LABELS

  while IFS=$'\t' read -r slug display_name; do
    [[ -n "$slug" ]] || continue
    add_unique_choice \
      "$slug" \
      "$display_name ($slug)" \
      PROJECT_OPTION_VALUES \
      PROJECT_OPTION_LABELS
  done < <(load_manifest_projects "$manifest")
}

normalize_tags_json() {
  local tags_csv="$1"
  if [[ -z "$tags_csv" ]]; then
    printf '[]'
    return 0
  fi

  local out=""
  local item
  IFS=',' read -r -a raw_tags <<<"$tags_csv"
  for item in "${raw_tags[@]}"; do
    item="$(slugify "$(trim_spaces "$item")")"
    [[ -z "$item" ]] && continue
    if [[ -n "$out" ]]; then
      out+=","
    fi
    out+="\"$item\""
  done
  printf '[%s]' "$out"
}

normalize_list_json() {
  local items_csv="$1"
  local mode="${2:-slug}"
  if [[ -z "$items_csv" ]]; then
    printf '[]'
    return 0
  fi

  local out=""
  local item=""
  IFS=',' read -r -a raw_items <<<"$items_csv"
  for item in "${raw_items[@]}"; do
    item="$(trim_spaces "$item")"
    [[ -z "$item" ]] && continue
    if [[ "$mode" == "slug" ]]; then
      item="$(slugify "$item")"
    fi
    [[ -z "$item" ]] && continue
    if [[ -n "$out" ]]; then
      out+=","
    fi
    out+="\"$item\""
  done
  printf '[%s]' "$out"
}

print_response_summary() {
  local response_file="$1"

  node -e '
const fs = require("fs");
const responseFile = process.argv[1];
let raw = "";
try {
  raw = fs.readFileSync(responseFile, "utf8");
} catch {}
const trimmed = String(raw || "").trim();
if (!trimmed) {
  console.log("kb: enviado com sucesso, mas o webhook nao retornou corpo de resposta.");
  process.exit(0);
}

let parsed;
try {
  parsed = JSON.parse(trimmed);
} catch {
  process.stdout.write(trimmed.endsWith("\n") ? trimmed : `${trimmed}\n`);
  process.exit(0);
}

if (parsed && typeof parsed === "object") {
  const ok = parsed.ok;
  const message = String(parsed.message || "").trim();
  const project = String(parsed.project || parsed.project_slug || "").trim();
  const kind = String(parsed.kind || "").trim();
  const canonicalPath = String(parsed.canonicalPath || parsed.canonical_path || "").trim();
  const followupPath = String(parsed.followupPath || parsed.followup_path || "").trim();
  const projectPath = String(parsed.projectPath || parsed.project_path || parsed.indexPath || parsed.index_path || "").trim();
  const notePath = String(parsed.notePath || parsed.note_path || parsed.noteRelativePath || "").trim();
  const reminderPath = String(parsed.reminderPath || parsed.reminder_path || "").trim();
  const attachmentPath = String(parsed.attachmentPath || parsed.attachment_path || "").trim();
  const attachmentMode = String(parsed.attachmentMode || parsed.attachment_mode || "").trim();
  const pushStatus = String(parsed.pushStatus || parsed.push_status || "").trim();

  if (ok === false) {
    console.log(`kb: falha${message ? ` - ${message}` : ""}`);
  } else {
    console.log("kb: nota enviada com sucesso.");
  }
  if (project) console.log(`project: ${project}`);
  if (kind) console.log(`kind: ${kind}`);
  if (notePath) console.log(`note: ${notePath}`);
  if (reminderPath) console.log(`reminder: ${reminderPath}`);
  if (canonicalPath) console.log(`canonical: ${canonicalPath}`);
  if (followupPath) console.log(`followup: ${followupPath}`);
  if (projectPath) console.log(`project_page: ${projectPath}`);
  if (attachmentPath) {
    console.log(`attachment: ${attachmentPath}${attachmentMode ? ` (${attachmentMode})` : ""}`);
  }
  if (pushStatus) console.log(`push: ${pushStatus}`);
  if (!project && !kind && !notePath && !reminderPath && !canonicalPath && !followupPath && !projectPath && !attachmentPath && !pushStatus && ok !== false) {
    process.stdout.write(`${JSON.stringify(parsed, null, 2)}\n`);
  }
  process.exit(ok === false ? 1 : 0);
}

process.stdout.write(`${trimmed}\n`);
' "$response_file"
}

build_manual_note_json_payload() {
  local event_id="$1"
  local triggered_at="$2"
  local project_slug="$3"
  local source="$4"
  local raw_text="$5"
  local kind="$6"
  local tags_json="$7"
  local note_type="$8"
  local importance="$9"
  local status="${10:-}"
  local follow_up_by="${11:-}"
  local decision_flag="${12:-}"
  local related_projects_json="${13:-}"
  local reminder_date="${14:-}"
  local reminder_time="${15:-}"
  local reminder_at="${16:-}"
  local attachment_abs="${17:-}"
  local attachment_name="${18:-}"
  local attachment_mime="${19:-}"
  local attachment_size="${20:-}"
  local attachment_sha256="${21:-}"

  node -e '
const fs = require("fs");
const [
  eventId,
  triggeredAt,
  projectSlug,
  source,
  rawText,
  kind,
  tagsJson,
  noteType,
  importance,
  status,
  followUpBy,
  decisionFlag,
  relatedProjectsJson,
  reminderDate,
  reminderTime,
  reminderAt,
  attachmentAbs,
  attachmentName,
  attachmentMime,
  attachmentSize,
  attachmentSha256,
] = process.argv.slice(1);

let tags = [];
try {
  const parsed = JSON.parse(tagsJson);
  if (Array.isArray(parsed)) tags = parsed;
} catch {}

let relatedProjects = [];
try {
  const parsed = JSON.parse(relatedProjectsJson);
  if (Array.isArray(parsed)) relatedProjects = parsed;
} catch {}

const payload = {
  event_type: "manual_note",
  event_id: eventId,
  triggered_at: triggeredAt,
  project_slug: projectSlug,
  source,
  raw_text: rawText,
  kind,
  tags,
  note_type: noteType || "",
  importance: importance || "",
  status: status || "",
  follow_up_by: followUpBy || "",
  decision_flag: String(decisionFlag || "").trim().toLowerCase() === "true",
  related_projects: relatedProjects,
  reminder_date: reminderDate || "",
  reminder_time: reminderTime || "",
  reminder_at: reminderAt || "",
};

if (attachmentAbs) {
  payload.attachment = {
    file_name: attachmentName || "attachment.bin",
    mime_type: attachmentMime || "application/octet-stream",
    size_bytes: Number(attachmentSize || 0) || 0,
    sha256: String(attachmentSha256 || "").trim().toLowerCase(),
    data_b64: fs.readFileSync(attachmentAbs).toString("base64"),
  };
}

process.stdout.write(JSON.stringify(payload));
' "$event_id" "$triggered_at" "$project_slug" "$source" "$raw_text" "$kind" "$tags_json" "$note_type" "$importance" "$status" "$follow_up_by" "$decision_flag" "$related_projects_json" "$reminder_date" "$reminder_time" "$reminder_at" "$attachment_abs" "$attachment_name" "$attachment_mime" "$attachment_size" "$attachment_sha256"
}

detect_project_from_git_manifest() {
  local manifest="$1"
  local remote_url=""
  local repo_full_name=""

  [[ -f "$manifest" ]] || return 1
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 1
  remote_url="$(git config --get remote.origin.url 2>/dev/null || true)"
  [[ -n "$remote_url" ]] || return 1

  repo_full_name="$(printf '%s' "$remote_url" | sed -E 's#^git@github.com:#https://github.com/#; s#\.git$##')"
  repo_full_name="$(printf '%s' "$repo_full_name" | sed -E 's#^https?://github.com/##; s#^ssh://git@github.com/##; s#^github.com/##; s#^/##')"
  [[ -n "$repo_full_name" ]] || return 1

  node -e '
const fs = require("fs");
const repo = process.argv[1].toLowerCase();
const manifest = process.argv[2];
try {
  const data = JSON.parse(fs.readFileSync(manifest, "utf8"));
  const projects = Array.isArray(data?.projects) ? data.projects : [];
  const found = projects.find((p) => String(p?.repo_full_name || "").toLowerCase() === repo);
  if (found?.project_slug) process.stdout.write(String(found.project_slug));
} catch {}
' "$repo_full_name" "$manifest"
}

infer_kind() {
  local text_lower
  text_lower="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"

  if [[ "$text_lower" =~ (erro|bug|falha|exception|stacktrace|quebrou|incidente) ]]; then
    printf 'bug high'
    return 0
  fi
  if [[ "$text_lower" =~ (resumo|summary|sumario|sintese|recap) ]]; then
    printf 'resume medium'
    return 0
  fi
  if [[ "$text_lower" =~ (artigo|article|tutorial|guia|documentacao|doc) ]]; then
    printf 'article medium'
    return 0
  fi
  if [[ "$text_lower" =~ (hoje|daily|diario|standup) ]]; then
    printf 'daily medium'
    return 0
  fi
  printf 'manual_note low'
}

resolve_webhook_url() {
  if [[ -n "${KB_WEBHOOK_URL:-}" ]]; then
    printf '%s' "$KB_WEBHOOK_URL"
    return 0
  fi

  if [[ -n "${WEBHOOK_URL:-}" ]]; then
    printf '%s' "$(join_url "$WEBHOOK_URL" "webhook/gH8xKbIngest0001/webhook/kb-event")"
    return 0
  fi

  return 1
}

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 1
fi

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

RAW_TEXT=""
PROJECT_SLUG=""
KIND=""
TAGS_CSV=""
NOTE_TYPE=""
IMPORTANCE=""
NOTE_STATUS=""
FOLLOW_UP_BY=""
REMINDER_DATE=""
REMINDER_TIME=""
REMINDER_AT=""
DECISION_FLAG="false"
RELATED_PROJECTS_CSV=""
ATTACHMENT_PATH=""
USE_DEFAULTS="false"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)
      PROJECT_SLUG="$(slugify "${2:-}")"
      shift 2
      ;;
    --kind)
      KIND="$(slugify "${2:-}")"
      shift 2
      ;;
    --tags)
      TAGS_CSV="${2:-}"
      shift 2
      ;;
    --note-type)
      NOTE_TYPE="$(slugify "${2:-}")"
      shift 2
      ;;
    --importance)
      IMPORTANCE="$(slugify "${2:-}")"
      shift 2
      ;;
    --status)
      NOTE_STATUS="$(slugify "${2:-}")"
      shift 2
      ;;
    --follow-up-by)
      FOLLOW_UP_BY="$(trim_spaces "${2:-}")"
      shift 2
      ;;
    --reminder-date)
      REMINDER_DATE="$(trim_spaces "${2:-}")"
      shift 2
      ;;
    --reminder-time)
      REMINDER_TIME="$(trim_spaces "${2:-}")"
      shift 2
      ;;
    --decision)
      DECISION_FLAG="true"
      shift
      ;;
    --related-projects)
      RELATED_PROJECTS_CSV="${2:-}"
      shift 2
      ;;
    --path)
      ATTACHMENT_PATH="${2:-}"
      shift 2
      ;;
    --default)
      USE_DEFAULTS="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [[ -z "$RAW_TEXT" ]]; then
        RAW_TEXT="$1"
      else
        RAW_TEXT="$RAW_TEXT $1"
      fi
      shift
      ;;
  esac
done

RAW_TEXT="$(trim_spaces "$RAW_TEXT")"
if [[ -z "$RAW_TEXT" ]]; then
  echo "kb: texto obrigatorio. Uso: kb \"<texto livre>\" [--path arquivo] [...]" >&2
  exit 1
fi

case "$KIND" in
  ""|manual-note)
    KIND="${KIND/manual-note/manual_note}"
    ;;
  manual_note|bug|resume|article|daily)
    ;;
  *)
    echo "kb: --kind invalido '$KIND' (use manual_note|bug|resume|article|daily)" >&2
    exit 1
    ;;
esac

if [[ -z "$KIND" ]]; then
  read -r inferred_kind inferred_confidence <<<"$(infer_kind "$RAW_TEXT")"
  KIND="$inferred_kind"
  if [[ "$USE_DEFAULTS" != "true" ]]; then
    build_kind_choices "$inferred_kind"
    KIND="$(
      prompt_numbered_choice \
        "kb: selecione o kind da anotacao:" \
        0 \
        KIND_OPTION_VALUES \
        KIND_OPTION_LABELS
    )"
  fi
fi

case "$NOTE_TYPE" in
  ""|event|knowledge|decision|incident)
    ;;
  *)
    echo "kb: --note-type invalido '$NOTE_TYPE' (use event|knowledge|decision|incident)" >&2
    exit 1
    ;;
esac

case "$IMPORTANCE" in
  ""|low|medium|high)
    ;;
  *)
    echo "kb: --importance invalido '$IMPORTANCE' (use low|medium|high)" >&2
    exit 1
    ;;
esac

case "$NOTE_STATUS" in
  ""|open|active|resolved|archived)
    ;;
  *)
    echo "kb: --status invalido '$NOTE_STATUS' (use open|active|resolved|archived)" >&2
    exit 1
    ;;
esac

if [[ -n "$REMINDER_DATE" ]]; then
  if ! validate_reminder_date_br "$REMINDER_DATE"; then
    echo "kb: --reminder-date invalido '$REMINDER_DATE' (use DD/MM/AAAA)" >&2
    exit 1
  fi
  REMINDER_DATE="$(normalize_reminder_date_br "$REMINDER_DATE")"
fi

if [[ -n "$REMINDER_TIME" ]]; then
  if ! validate_reminder_time "$REMINDER_TIME"; then
    echo "kb: --reminder-time invalido '$REMINDER_TIME' (use HH:mm)" >&2
    exit 1
  fi
fi

if [[ -n "$REMINDER_TIME" && -z "$REMINDER_DATE" ]]; then
  echo "kb: --reminder-time exige --reminder-date." >&2
  exit 1
fi

if [[ -z "$REMINDER_DATE" && "$USE_DEFAULTS" != "true" ]]; then
  collect_reminder_schedule
fi

if [[ -n "$REMINDER_DATE" && -n "$REMINDER_TIME" ]]; then
  REMINDER_AT="${REMINDER_DATE}T${REMINDER_TIME}:00-03:00"
fi

DETECTED_PROJECT_SLUG=""
if [[ -z "$PROJECT_SLUG" ]]; then
  if [[ -f "$SCRIPT_DIR/projects.json" ]]; then
    DETECTED_PROJECT_SLUG="$(detect_project_from_git_manifest "$SCRIPT_DIR/projects.json" || true)"
  fi
fi

DEFAULT_PROJECT_SLUG="$(slugify "${KB_NOTE_DEFAULT_PROJECT:-inbox}")"
if [[ -z "$DEFAULT_PROJECT_SLUG" ]]; then
  DEFAULT_PROJECT_SLUG="inbox"
fi

if [[ -z "$PROJECT_SLUG" ]]; then
  if [[ "$USE_DEFAULTS" == "true" ]]; then
    PROJECT_SLUG="${DETECTED_PROJECT_SLUG:-$DEFAULT_PROJECT_SLUG}"
  else
    build_project_choices "$SCRIPT_DIR/projects.json" "$DETECTED_PROJECT_SLUG" "$DEFAULT_PROJECT_SLUG"
    PROJECT_SLUG="$(
      prompt_numbered_choice \
        "kb: selecione o projeto:" \
        0 \
        PROJECT_OPTION_VALUES \
        PROJECT_OPTION_LABELS
    )"
  fi
fi

PROJECT_SLUG="$(slugify "${PROJECT_SLUG:-$DEFAULT_PROJECT_SLUG}")"
if [[ -z "$PROJECT_SLUG" ]]; then
  PROJECT_SLUG="inbox"
fi

ATTACHMENT_ABS=""
ATTACHMENT_NAME=""
ATTACHMENT_MIME=""
ATTACHMENT_SIZE_BYTES=""
ATTACHMENT_SHA256=""
if [[ -n "$ATTACHMENT_PATH" ]]; then
  if [[ ! -f "$ATTACHMENT_PATH" ]]; then
    echo "kb: arquivo nao encontrado: $ATTACHMENT_PATH" >&2
    exit 1
  fi
  if [[ ! -r "$ATTACHMENT_PATH" ]]; then
    echo "kb: sem permissao de leitura: $ATTACHMENT_PATH" >&2
    exit 1
  fi
  ATTACHMENT_ABS="$(cd "$(dirname "$ATTACHMENT_PATH")" && pwd)/$(basename "$ATTACHMENT_PATH")"
  ATTACHMENT_NAME="$(basename "$ATTACHMENT_ABS")"
  ATTACHMENT_SIZE_BYTES="$(wc -c <"$ATTACHMENT_ABS" | tr -d '[:space:]')"
  if command -v file >/dev/null 2>&1; then
    ATTACHMENT_MIME="$(file --mime-type -b "$ATTACHMENT_ABS" 2>/dev/null || true)"
  fi
  ATTACHMENT_MIME="${ATTACHMENT_MIME:-application/octet-stream}"
  if command -v sha256sum >/dev/null 2>&1; then
    ATTACHMENT_SHA256="$(sha256sum "$ATTACHMENT_ABS" | awk '{print $1}')"
  elif command -v shasum >/dev/null 2>&1; then
    ATTACHMENT_SHA256="$(shasum -a 256 "$ATTACHMENT_ABS" | awk '{print $1}')"
  else
    echo "kb: sha256sum/shasum nao encontrado para calcular hash do arquivo" >&2
    exit 1
  fi
fi

WEBHOOK_URL_RESOLVED="$(resolve_webhook_url || true)"
if [[ -z "$WEBHOOK_URL_RESOLVED" ]]; then
  echo "kb: KB_WEBHOOK_URL nao configurado (ou WEBHOOK_URL ausente)." >&2
  exit 1
fi
if [[ -z "${KB_WEBHOOK_SECRET:-}" ]]; then
  echo "kb: KB_WEBHOOK_SECRET nao configurado." >&2
  exit 1
fi

EVENT_ID="manual:$(date -u +%Y%m%d%H%M%S):$RANDOM"
EVENT_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
TAGS_JSON="$(normalize_tags_json "$TAGS_CSV")"
RELATED_PROJECTS_JSON="$(normalize_list_json "$RELATED_PROJECTS_CSV" "slug")"

PAYLOAD_FILE="$(mktemp)"
RESPONSE_FILE="$(mktemp)"
cleanup() {
  rm -f "$PAYLOAD_FILE"
  rm -f "$RESPONSE_FILE"
}
trap cleanup EXIT

build_manual_note_json_payload \
  "$EVENT_ID" \
  "$EVENT_AT" \
  "$PROJECT_SLUG" \
  "kb-cli" \
  "$RAW_TEXT" \
  "$KIND" \
  "$TAGS_JSON" \
  "$NOTE_TYPE" \
  "$IMPORTANCE" \
  "$NOTE_STATUS" \
  "$FOLLOW_UP_BY" \
  "$DECISION_FLAG" \
  "$RELATED_PROJECTS_JSON" \
  "$REMINDER_DATE" \
  "$REMINDER_TIME" \
  "$REMINDER_AT" \
  "$ATTACHMENT_ABS" \
  "$ATTACHMENT_NAME" \
  "$ATTACHMENT_MIME" \
  "$ATTACHMENT_SIZE_BYTES" \
  "$ATTACHMENT_SHA256" >"$PAYLOAD_FILE"

if ! curl \
  --silent \
  --show-error \
  --fail-with-body \
  -X POST "$WEBHOOK_URL_RESOLVED" \
  -H "x-kb-secret: $KB_WEBHOOK_SECRET" \
  -H "Content-Type: application/json" \
  --data-binary "@$PAYLOAD_FILE" \
  -o "$RESPONSE_FILE"; then
  if [[ -s "$RESPONSE_FILE" ]]; then
    cat "$RESPONSE_FILE" >&2
    echo >&2
  fi
  exit 1
fi

print_response_summary "$RESPONSE_FILE"
