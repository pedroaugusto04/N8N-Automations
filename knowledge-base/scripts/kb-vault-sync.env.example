# Copy to (inside n8n container mount):
# /home/node/.n8n/kb-vault-sync.env

KB_VAULT_REPO_DIR=/home/node/knowledge-vault
KB_VAULT_GIT_BRANCH=main

# Commit identity
KB_VAULT_GIT_USER_NAME=Pedro Duarte
KB_VAULT_GIT_USER_EMAIL=pedro@example.com

# Required only for HTTPS remotes
KB_VAULT_GIT_PUSH_USERNAME=your_github_username
KB_VAULT_GIT_PUSH_TOKEN=ghp_xxx
