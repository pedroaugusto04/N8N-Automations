{
  "name": "@n8n-automations/knowledge-base",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build:api": "tsc -p tsconfig.json",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build": "npm run clean && npm run build:api && npm run build:frontend",
    "dev:api": "node --loader ts-node/esm src/main.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "test:api": "npm run clean && npm run build:api && node --test tests/*.test.mjs",
    "test:frontend": "vitest run --config frontend/vite.config.ts",
    "test": "npm run test:api && npm run test:frontend"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@tanstack/react-query": "^5.62.8",
    "reflect-metadata": "^0.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "rxjs": "^7.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/node": "^24.3.0",
    "jsdom": "^25.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
