[
  {
    "name": "KB Adapter - WhatsApp",
    "active": true,
    "nodes": [
      {
        "parameters": {
          "httpMethod": "POST",
          "path": "whatsapp-kb-event",
          "responseMode": "responseNode",
          "options": {
            "rawBody": true
          }
        },
        "id": "kb-wpp-webhook",
        "name": "WhatsApp Webhook",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 2,
        "position": [
          0,
          0
        ]
      },
      {
        "parameters": {
          "jsCode": "const item = $input.first() || {};\nconst json = item.json || {};\nconst body = json.body && typeof json.body === 'object' ? json.body : json;\nlet data = body.data || body;\nif (Array.isArray(data)) data = data[0];\nconst event = String(body.event || '').trim().toUpperCase().replace(/[.-]/g, '_');\nif (event && event !== 'MESSAGES_UPSERT') {\n  return [{ json: { skip: true, reason: `unsupported_event:${event}` } }];\n}\nconst key = data?.key || {};\nconst msgContent = data?.message || {};\nconst remoteJid = String(key.remoteJid || '').trim();\nif (!remoteJid.endsWith('@g.us')) return [{ json: { skip: true, reason: 'not_group' } }];\nconst allowedGroup = String($env.WPP_KB_GROUP_JID || '').trim();\nif (allowedGroup && remoteJid !== allowedGroup) return [{ json: { skip: true, reason: 'wrong_group' } }];\nconst innerMsg = msgContent.ephemeralMessage?.message || msgContent.viewOnceMessage?.message || msgContent;\nconst mediaTypes = [\n  { key: 'imageMessage', type: 'image' },\n  { key: 'documentMessage', type: 'document' },\n  { key: 'audioMessage', type: 'audio' },\n  { key: 'videoMessage', type: 'video' }\n];\nlet mediaType = '';\nlet mediaData = null;\nlet mediaFileName = '';\nlet mediaMimeType = '';\nfor (const mt of mediaTypes) {\n  if (innerMsg[mt.key]) {\n    mediaType = mt.type;\n    mediaData = innerMsg[mt.key];\n    mediaFileName = String(mediaData.fileName || mediaData.title || `attachment.${mt.type}`).trim();\n    mediaMimeType = String(mediaData.mimetype || '').trim();\n    break;\n  }\n}\nconst messageText = String((mediaData && mediaData.caption) || innerMsg.conversation || innerMsg.extendedTextMessage?.text || '').trim();\nif (!messageText && !mediaType) return [{ json: { skip: true, reason: 'empty' } }];\nreturn [{ json: {\n  skip: false,\n  message_text: messageText || (mediaType ? `[${mediaType}: ${mediaFileName}]` : ''),\n  sender_jid: String(key.participant || key.remoteJid || '').trim(),\n  group_jid: remoteJid,\n  message_id: String(key.id || '').trim(),\n  has_media: Boolean(mediaType),\n  media_type: mediaType,\n  media_file_name: mediaFileName,\n  media_mime_type: mediaMimeType,\n  media_file_size: Number(mediaData?.fileLength || 0),\n  raw_message: JSON.stringify(key),\n} }];"
        },
        "id": "kb-wpp-parse",
        "name": "Parse WhatsApp Event",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          240,
          0
        ]
      },
      {
        "parameters": {
          "conditions": {
            "options": {
              "version": 2
            },
            "conditions": [
              {
                "leftValue": "={{ String($json.skip) }}",
                "rightValue": "true",
                "operator": {
                  "type": "string",
                  "operation": "equals"
                }
              }
            ],
            "combinator": "and"
          }
        },
        "id": "kb-wpp-skip",
        "name": "Should Skip?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.2,
        "position": [
          480,
          0
        ]
      },
      {
        "parameters": {
          "conditions": {
            "options": {
              "version": 2
            },
            "conditions": [
              {
                "leftValue": "={{ String($json.has_media) }}",
                "rightValue": "true",
                "operator": {
                  "type": "string",
                  "operation": "equals"
                }
              }
            ],
            "combinator": "and"
          }
        },
        "id": "kb-wpp-has-media",
        "name": "Has Media?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.2,
        "position": [
          720,
          0
        ]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "={{ $env.EVOLUTION_API_URL }}/chat/getBase64FromMediaMessage/{{ $env.EVOLUTION_INSTANCE_NAME }}",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "apikey",
                "value": "={{ $env.EVOLUTION_API_KEY }}"
              }
            ]
          },
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ JSON.stringify({ message: JSON.parse($json.raw_message) }) }}"
        },
        "id": "kb-wpp-download-media",
        "name": "Download Media",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          960,
          -96
        ]
      },
      {
        "parameters": {
          "jsCode": "const base = $node['Has Media?'].json;\nreturn [{ json: { ...base, media_data_b64: String($json.base64 || '').trim() } }];"
        },
        "id": "kb-wpp-merge-media",
        "name": "Merge Media Data",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1200,
          -96
        ]
      },
      {
        "parameters": {
          "jsCode": "return [{ json: { ...$json, media_data_b64: '' } }];"
        },
        "id": "kb-wpp-no-media",
        "name": "No Media Path",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          960,
          96
        ]
      },
      {
        "parameters": {
          "jsCode": "const payload = {\n  messageText: $json.message_text || '',\n  senderId: $json.sender_jid || '',\n  groupId: $json.group_jid || '',\n  messageId: $json.message_id || '',\n  hasMedia: Boolean($json.has_media),\n  media: {\n    fileName: $json.media_file_name || '',\n    mimeType: $json.media_mime_type || 'application/octet-stream',\n    sizeBytes: Number($json.media_file_size || 0),\n    dataBase64: $json.media_data_b64 || ''\n  }\n};\nconst encoded = Buffer.from(JSON.stringify(payload), 'utf8').toString('base64');\nconst tempPath = `/tmp/kb-wpp-${Date.now()}-${Math.random().toString(16).slice(2)}.b64`;\nreturn [{ json: { payload_b64: encoded, payload_file_path: tempPath } }];"
        },
        "id": "kb-wpp-prepare",
        "name": "Prepare Conversation Input",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1440,
          0
        ]
      },
      {
        "parameters": {
          "command": "=echo '{{$json.payload_b64}}' > '{{$json.payload_file_path}}' && node /home/node/knowledge-base/dist/cli/conversation.js --file '{{$json.payload_file_path}}'; rm -f '{{$json.payload_file_path}}'"
        },
        "id": "kb-wpp-run-conversation",
        "name": "Run Conversation CLI",
        "type": "n8n-nodes-base.executeCommand",
        "typeVersion": 1,
        "position": [
          1680,
          0
        ]
      },
      {
        "parameters": {
          "jsCode": "const stdout = String($json.stdout || '').trim();\nlet parsed;\ntry {\n  parsed = JSON.parse(stdout || '{}');\n} catch {\n  parsed = { action: 'error', replyText: stdout || 'invalid_json_from_conversation_cli', payload: null };\n}\nreturn [{ json: parsed }];"
        },
        "id": "kb-wpp-parse-conversation",
        "name": "Parse Conversation Result",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1920,
          0
        ]
      },
      {
        "parameters": {
          "conditions": {
            "options": {
              "version": 2
            },
            "conditions": [
              {
                "leftValue": "={{ $json.action }}",
                "rightValue": "submit",
                "operator": {
                  "type": "string",
                  "operation": "equals"
                }
              }
            ],
            "combinator": "and"
          }
        },
        "id": "kb-wpp-is-submit",
        "name": "Is Submit?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.2,
        "position": [
          2160,
          0
        ]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "={{ $env.EVOLUTION_API_URL }}/message/sendText/{{ $env.EVOLUTION_INSTANCE_NAME }}",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "apikey",
                "value": "={{ $env.EVOLUTION_API_KEY }}"
              }
            ]
          },
          "sendBody": true,
          "bodyParameters": {
            "parameters": [
              {
                "name": "number",
                "value": "={{ $env.WPP_KB_GROUP_JID }}"
              },
              {
                "name": "text",
                "value": "={{ '[BOT] ' + ($json.replyText || '') }}"
              }
            ]
          }
        },
        "id": "kb-wpp-send-reply",
        "name": "Send WhatsApp Reply",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          2400,
          -96
        ]
      },
      {
        "parameters": {
          "jsCode": "const payload = $node['Parse Conversation Result'].json.payload;\nconst encoded = Buffer.from(JSON.stringify(payload || {}), 'utf8').toString('base64');\nconst tempPath = `/tmp/kb-wpp-submit-${Date.now()}-${Math.random().toString(16).slice(2)}.b64`;\nreturn [{ json: { payload_b64: encoded, payload_file_path: tempPath } }];"
        },
        "id": "kb-wpp-prepare-ingest",
        "name": "Prepare Ingest Payload",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          2400,
          96
        ]
      },
      {
        "parameters": {
          "command": "=echo '{{$json.payload_b64}}' > '{{$json.payload_file_path}}' && node /home/node/knowledge-base/dist/cli/ingest.js --file '{{$json.payload_file_path}}'; rm -f '{{$json.payload_file_path}}'"
        },
        "id": "kb-wpp-run-ingest",
        "name": "Run Ingest CLI",
        "type": "n8n-nodes-base.executeCommand",
        "typeVersion": 1,
        "position": [
          2640,
          96
        ]
      },
      {
        "parameters": {
          "jsCode": "const stdout = String($json.stdout || '').trim();\nlet parsed;\ntry {\n  parsed = JSON.parse(stdout || '{}');\n} catch {\n  parsed = { ok: false, message: stdout || 'invalid_json_from_ingest_cli' };\n}\nconst text = parsed.ok ? `Nota salva no vault\\nProjeto: ${parsed.project || ''}\\nNota: ${parsed.eventPath || ''}` : `Falha ao salvar nota: ${parsed.message || 'erro desconhecido'}`;\nreturn [{ json: { ...parsed, confirmText: text } }];"
        },
        "id": "kb-wpp-parse-ingest",
        "name": "Parse Ingest Result",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          2880,
          96
        ]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "={{ $env.EVOLUTION_API_URL }}/message/sendText/{{ $env.EVOLUTION_INSTANCE_NAME }}",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "apikey",
