              },
              {
                "name": "text",
                "value": "={{ '[BOT] ' + $json.confirmText }}"
              }
            ]
          }
        },
        "id": "kb-wpp-send-confirmation",
        "name": "Send Confirmation",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
