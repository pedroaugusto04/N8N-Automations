[
  {
    "id": "gH8xKbIngest0001",
    "name": "Knowledge Base - Ingestion",
    "active": true,
    "nodes": [
      {
        "parameters": {
          "httpMethod": "POST",
          "path": "kb-event",
          "responseMode": "responseNode",
          "options": {
            "rawBody": true,
            "binaryData": true
          }
        },
        "id": "c0ec733f-a36a-4974-b759-872fd8e21650",
        "name": "Webhook",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 2,
        "position": [
          0,
          160
        ]
      },
      {
        "parameters": {
          "jsCode": "const item = $input.first() || {};\nconst json = item.json || {};\nconst body = json.body && typeof json.body === 'object' ? json.body : json;\nconst headers = json.headers && typeof json.headers === 'object' ? json.headers : {};\nconst binaries = item.binary && typeof item.binary === 'object' ? item.binary : {};\nconst payload = {\n  headers,\n  body,\n  binaries,\n  raw_body_b64: binaries?.data?.data || '',\n  received_at: new Date().toISOString(),\n};\nconst payloadB64 = Buffer.from(JSON.stringify(payload), 'utf8').toString('base64');\nconst payloadFilePath =   `/tmp/kb-payload-${Date.now()}-${Math.random().toString(16).slice(2)}.b64`;\nconst payloadFileBinary = Buffer.from(payloadB64, 'utf8').toString('base64');\nreturn [{\n  json: {\n    payload_file_path: payloadFilePath,\n    incoming_body: body,\n  },\n  binary: {\n    payload_file: {\n      data: payloadFileBinary,\n      fileName: 'kb-payload.b64',\n      mimeType: 'text/plain',\n    },\n  },\n}];"
        },
        "id": "fc811629-c804-48d4-b5d8-b63786a0d6aa",
        "name": "Prepare Payload",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          256,
          160
        ]
      },
      {
        "parameters": {
          "command": "=node /home/node/knowledge-base/process-event-v2.mjs --file '{{$json.payload_file_path}}'; rm -f '{{$json.payload_file_path}}'"
        },
        "id": "4af87b4c-7f14-4556-9b9f-c77ffbd3c75c",
        "name": "Run Processor",
        "type": "n8n-nodes-base.executeCommand",
        "typeVersion": 1,
        "position": [
          512,
          160
        ]
      },
      {
        "parameters": {
          "jsCode": "const stdout = String($json.stdout || '').trim();\nlet parsed;\ntry {\n  parsed = JSON.parse(stdout || '{}');\n} catch {\n  parsed = {\n    ok: false,\n    status: 'invalid_processor_output',\n    message: stdout || 'processor returned no json',\n  };\n}\nreturn [{ json: parsed }];"
        },
        "id": "181f2e58-240f-49fc-b09e-55fa3159d66a",
        "name": "Parse Result",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          768,
          160
        ]
      },
      {
        "parameters": {
          "respondWith": "json",
          "responseBody": "={{ $json }}",
          "options": {
            "responseCode": 200
          }
        },
        "id": "1ba3b7ec-4c14-478c-b732-9b553511e1a7",
        "name": "Respond to Webhook",
        "type": "n8n-nodes-base.respondToWebhook",
        "typeVersion": 1.1,
        "position": [
          1024,
          64
        ]
      },
      {
        "parameters": {
          "conditions": {
            "options": {
              "caseSensitive": true,
              "leftValue": "",
              "typeValidation": "strict",
              "version": 2
            },
            "conditions": [
              {
                "id": "1d9f70c0-3145-4064-9ffb-cf89f1efaf01",
                "leftValue": "={{ String($json.ok) }}",
                "rightValue": "false",
                "operator": {
                  "type": "string",
                  "operation": "equals",
                  "name": "filter.operator.equals"
                }
              }
            ],
            "combinator": "and"
          },
          "options": {}
        },
        "id": "5f0613aa-dd3f-45b7-8d0b-8eca57597ffd",
        "name": "Needs Alert?",
