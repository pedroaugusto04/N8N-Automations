        ]
      },
      {
        "parameters": {
          "chatId": "={{ $env.VPS_TELEGRAM_CHAT_ID }}",
          "text": "={{ $json.alertMessage || $json.message || 'Knowledge base ingestion failed' }}",
          "additionalFields": {
            "appendAttribution": false
          }
        },
        "id": "8eef5a2f-b040-45a9-9355-4799c61d599f",
        "name": "Telegram Failure Alert",
