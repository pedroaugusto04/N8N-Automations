FROM node:20-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/home/node
ENV PATH=/home/node/.opencode/bin:/home/node/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

RUN apt-get update \
  && apt-get install -y --no-install-recommends bash ca-certificates curl git procps ripgrep \
  && rm -rf /var/lib/apt/lists/*

USER node
WORKDIR /home/node

RUN mkdir -p /home/node/.local/share/opencode /home/node/.config/opencode /home/node/.cache/opencode \
  && curl -fsSL https://opencode.ai/install | bash

WORKDIR /home/node/knowledge-base
EXPOSE 8787

CMD ["node", "/home/node/knowledge-base/kb-agent-server.mjs"]
